{
  "name": "@rocosenyyy/octo-cli",
  "version": "0.3.0",
  "description": "八爪鱼采集器命令行工具 - 通过终端控制八爪鱼客户端",
  "main": "dist/index.js",
  "bin": {
    "octo": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rocosen/octo-cli.git"
  },
  "homepage": "https://github.com/rocosen/octo-cli#readme",
  "bugs": {
    "url": "https://github.com/rocosen/octo-cli/issues"
  },
  "keywords": [
    "octopus",
    "octoparse",
    "scraper",
    "cli",
    "八爪鱼"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/prompts": "^2.4.9",
    "commander": "^12.0.0",
    "node-ipc": "9.2.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
